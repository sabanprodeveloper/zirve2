# Railway'de kullanmak için:
# credentials.json'u base64 ile encode et ve aşağıya yapıştır
# Windows PowerShell:
# $content = Get-Content "credentials.json" -Raw
# [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes($content)) | Set-Clipboard

# Mac/Linux:
# cat credentials.json | base64 | pbcopy

GOOGLE_
FIREBASE_
PORT=3000
